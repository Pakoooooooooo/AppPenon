<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Titre -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Main"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <!-- Adresse MAC cible -->
    <TextView
        android:id="@+id/tvTargetMac"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Appareil eTT-SAIL: F3:B9:F6:76:07:8F"
        android:textSize="14sp"
        android:textStyle="bold"
        android:padding="8dp"
        android:background="#C8E6C9"
        android:textColor="#2E7D32"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <!-- Statut -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Prêt à écouter"
        android:textSize="16sp"
        android:padding="12dp"
        android:background="#E3F2FD"
        android:textColor="#1976D2"
        android:layout_marginBottom="12dp" />

    <!-- Boutons de contrôle -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/btnStartScan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Démarrer"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnStopScan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Arrêter"
            android:enabled="false"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnClearData"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Effacer"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <!-- Données décodées (partie supérieure) -->

    <!-- Etats des pennons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/tvEtatPenon1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Babord : ⏳ En attente..."
                android:textSize="15sp"
                android:padding="6dp"
                android:background="#FFF3E0"
                android:textColor="#E65100"
                android:layout_weight="2"/>

            <Button
                android:id="@+id/btnParamPenon1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Paramettres"
                android:layout_weight="1"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/tvEtatPenon2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tribord : ⏳ En attente..."
                android:textSize="15sp"
                android:padding="6dp"
                android:background="#E8F5E9"
                android:textColor="#1B5E20"
                android:layout_weight="2"/>

            <Button
                android:id="@+id/btnParamPenon2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Paramettres"
                android:layout_weight="1"/>
        </LinearLayout>


    </LinearLayout>

    <!-- Séparateur -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#CCCCCC"
        android:layout_marginBottom="8dp" />

    <!-- Données brutes (partie inférieure) -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔧 Données brutes (HEX) :"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#F5F5F5"
        android:padding="8dp">

        <TextView
            android:id="@+id/tvReceivedData"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cliquez sur 'Démarrer' pour écouter..."
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textColor="#000000" />
    </ScrollView>

</LinearLayout>