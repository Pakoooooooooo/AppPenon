<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Titre -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="eTT-SAIL Dual Monitor"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <!-- Statut -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Prêt à écouter"
            android:textSize="14sp"
            android:layout_weight="1"
            android:padding="12dp"
            android:background="#E3F2FD"
            android:textColor="#1976D2"
            android:layout_marginBottom="12dp" />
        <Button
            android:id="@+id/appModeBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="0"
            android:text="Settings" />
    </LinearLayout>

    <!-- Nom du fichier -->
    <EditText
        android:id="@+id/etFileName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nom de base des fichiers (optionnel)"
        android:inputType="text"
        android:maxLines="1"
        android:padding="12dp"
        android:layout_marginBottom="8dp" />

    <!-- Adresses MAC -->

    <!-- Boutons de contrôle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/btnStartScan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="▶ Démarrer"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnStopScan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⏹ Arrêter"
            android:enabled="false"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnClearData"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🗑 Effacer"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <!-- Séparateur -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#CCCCCC"
        android:layout_marginBottom="8dp" />

    <!-- Conteneur avec ScrollView pour tout le contenu -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- En-têtes des penons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp"/>

            <!-- Données décodées -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📊 Données décodées"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <ScrollView
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:background="#FAFAFA"
                    android:padding="8dp"
                    android:layout_marginEnd="4dp">

                    <TextView
                        android:id="@+id/tvParsedData"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="En attente..."
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:textColor="#000000" />
                </ScrollView>

            </LinearLayout>

            <!-- Séparateur -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginBottom="8dp" />

            <!-- Données brutes (HEX) -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔧 Données brutes (HEX)"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ScrollView
                    android:id="@+id/scrollView"
                    android:layout_width="0dp"
                    android:layout_height="180dp"
                    android:layout_weight="1"
                    android:background="#F5F5F5"
                    android:padding="8dp"
                    android:layout_marginEnd="4dp">

                    <TextView
                        android:id="@+id/tvReceivedData"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Prêt..."
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:textColor="#424242" />
                </ScrollView>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>